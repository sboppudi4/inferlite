{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["inferlite"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "",
  "title": "InferLite Inference Overview",
  "uid": "inferlite-overview",
  "version": 1,
  "panels": [
    {
      "title": "Request Latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(inferlite_request_latency_seconds_bucket[5m])) by (le,endpoint,tier))", "legendFormat": "p50 {{endpoint}}/{{tier}}" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(inferlite_request_latency_seconds_bucket[5m])) by (le,endpoint,tier))", "legendFormat": "p95 {{endpoint}}/{{tier}}" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(inferlite_request_latency_seconds_bucket[5m])) by (le,endpoint,tier))", "legendFormat": "p99 {{endpoint}}/{{tier}}" }
      ]
    },
    {
      "title": "TTFT (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(inferlite_ttft_seconds_bucket[5m])) by (le,endpoint,tier))", "legendFormat": "{{endpoint}}/{{tier}}" }
      ]
    },
    {
      "title": "TPOT (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(inferlite_tpot_seconds_bucket[5m])) by (le,endpoint,tier))", "legendFormat": "{{endpoint}}/{{tier}}" }
      ]
    },
    {
      "title": "Token Throughput (prefill / decode)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "tps" }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(inferlite_prefill_tokens_total[1m])", "legendFormat": "prefill tok/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(inferlite_decode_tokens_total[1m])", "legendFormat": "decode tok/s" }
      ]
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "inferlite_queue_depth", "legendFormat": "queue depth" }
      ]
    },
    {
      "title": "KV Cache Utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "inferlite_kv_cache_utilization", "legendFormat": "utilization" }
      ]
    }
  ]
}
